               OpCapability Shader
               OpMemoryModel Logical Simple
               OpEntryPoint Vertex %1 "main::<f32>" %in1 %out1
               OpEntryPoint Vertex %4 "main::<u32>" %in1 %out1
               OpEntryPoint Vertex %7 "main::<()>"
               OpName %in1 "in1"
               OpName %out1 "out1"
               OpName %in1 "in1"
               OpName %out1 "out1"
               OpDecorate %in1 Location 0
               OpDecorate %out1 Location 0
               OpDecorate %in1 Location 0
               OpDecorate %out1 Location 0
        %f32 = OpTypeFloat 32
%_ptr_Input_f32 = OpTypePointer Input %f32
%_ptr_Output_f32 = OpTypePointer Output %f32
       %void = OpTypeVoid
         %13 = OpTypeFunction %void
        %in1 = OpVariable %_ptr_Input_f32 Input
       %out1 = OpVariable %_ptr_Output_f32 Output
        %u32 = OpTypeInt 32 0
%_ptr_Input_u32 = OpTypePointer Input %u32
%_ptr_Output_u32 = OpTypePointer Output %u32
        %in1 = OpVariable %_ptr_Input_u32 Input
       %out1 = OpVariable %_ptr_Output_u32 Output
          %1 = OpFunction %void None %13
         %17 = OpLabel
         %18 = OpLoad %f32 %in1
               OpStore %out1 %18
               OpNoLine
               OpReturn
               OpFunctionEnd
          %4 = OpFunction %void None %13
         %19 = OpLabel
         %20 = OpLoad %u32 %in1
               OpStore %out1 %20
               OpNoLine
               OpReturn
               OpFunctionEnd
          %7 = OpFunction %void None %13
         %21 = OpLabel
               OpReturn
               OpFunctionEnd
