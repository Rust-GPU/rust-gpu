               OpCapability Shader
               OpMemoryModel Logical Simple
               OpEntryPoint Vertex %1 "main" %input %output
               OpName %input "input"
               OpName %output "output"
               OpDecorate %input Location 0
               OpDecorate %output Location 0
        %f32 = OpTypeFloat 32
      %v4f32 = OpTypeVector %f32 4
%_ptr_Input_v4f32 = OpTypePointer Input %v4f32
%_ptr_Output_v4f32 = OpTypePointer Output %v4f32
       %void = OpTypeVoid
         %12 = OpTypeFunction %void
      %input = OpVariable %_ptr_Input_v4f32 Input
      %f32_1 = OpConstant %f32 1
     %output = OpVariable %_ptr_Output_v4f32 Output
          %1 = OpFunction %void None %12
         %14 = OpLabel
         %15 = OpLoad %v4f32 %input
         %16 = OpCompositeConstruct %v4f32 %f32_1 %f32_1 %f32_1 %f32_1
         %17 = OpFAdd %v4f32 %15 %16
               OpStore %output %17
               OpNoLine
               OpReturn
               OpFunctionEnd
