OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint GLCompute %1 "entry_1" %2
OpExecutionMode %1 LocalSize 1 1 1
OpName %5 "builtin_duplicate_std_local_def::entry_1"
OpName %6 "builtin_duplicate_std_local_def::local3"
OpDecorate %2 BuiltIn LocalInvocationIndex
%7 = OpTypeVoid
%8 = OpTypeFunction %7
%9 = OpTypeInt 32 0
%10 = OpTypePointer Input %9
%2 = OpVariable  %10  Input
%11 = OpTypeFunction %9
%1 = OpFunction  %7  None %8
%12 = OpLabel
%13 = OpFunctionCall  %7  %5
OpNoLine
OpReturn
OpFunctionEnd
%5 = OpFunction  %7  None %8
%14 = OpLabel
%15 = OpLoad  %9  %2
%16 = OpLoad  %9  %2
%17 = OpFunctionCall  %9  %6
OpNoLine
OpReturn
OpFunctionEnd
%6 = OpFunction  %9  DontInline %11
%18 = OpLabel
%19 = OpLoad  %9  %2
OpNoLine
OpReturnValue %19
OpFunctionEnd
