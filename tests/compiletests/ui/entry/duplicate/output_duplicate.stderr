OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint Fragment %1 "main" %2 %3
OpExecutionMode %1 OriginUpperLeft
OpName %3 "output2"
OpDecorate %2 Location 0
OpDecorate %3 Location 1
%5 = OpTypeFloat 32
%6 = OpTypePointer Output %5
%7 = OpTypeVoid
%8 = OpTypeFunction %7
%2 = OpVariable  %6  Output
%9 = OpConstant  %5  42
%3 = OpVariable  %6  Output
%10 = OpConstant  %5  69
%1 = OpFunction  %7  None %8
%11 = OpLabel
OpStore %2 %9
OpStore %3 %10
OpNoLine
OpReturn
OpFunctionEnd
