OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint Fragment %1 "main" %2 %3 %4
OpExecutionMode %1 OriginUpperLeft
OpName %3 "input2"
OpName %4 "output"
OpDecorate %2 Location 0
OpDecorate %3 Location 1
OpDecorate %4 Location 0
%6 = OpTypeFloat 32
%7 = OpTypePointer Input %6
%8 = OpTypePointer Output %6
%9 = OpTypeVoid
%10 = OpTypeFunction %9
%2 = OpVariable  %7  Input
%3 = OpVariable  %7  Input
%4 = OpVariable  %8  Output
%1 = OpFunction  %9  None %10
%11 = OpLabel
%12 = OpLoad  %6  %2
%13 = OpLoad  %6  %3
%14 = OpFAdd  %6  %12 %13
OpStore %4 %14
OpNoLine
OpReturn
OpFunctionEnd
