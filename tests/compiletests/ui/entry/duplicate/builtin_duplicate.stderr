OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint GLCompute %1 "entry_1" %2
OpExecutionMode %1 LocalSize 1 1 1
OpName %5 "builtin_duplicate::entry_1"
OpDecorate %2 BuiltIn LocalInvocationIndex
%6 = OpTypeVoid
%7 = OpTypeFunction %6
%8 = OpTypeInt 32 0
%9 = OpTypePointer Input %8
%2 = OpVariable  %9  Input
%1 = OpFunction  %6  None %7
%10 = OpLabel
%11 = OpFunctionCall  %6  %5
OpNoLine
OpReturn
OpFunctionEnd
%5 = OpFunction  %6  None %7
%12 = OpLabel
%13 = OpLoad  %8  %2
%14 = OpLoad  %8  %2
OpNoLine
OpReturn
OpFunctionEnd
