OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint Vertex %1 "vertex" %2 %3 %4
OpName %2 "buffer_positions"
OpDecorate %7 ArrayStride 16
OpDecorate %8 Block
OpMemberDecorate %8 0 Offset 0
OpDecorate %2 NonWritable
OpDecorate %2 Binding 0
OpDecorate %2 DescriptorSet 0
OpDecorate %3 BuiltIn VertexIndex
OpDecorate %4 BuiltIn Position
%9 = OpTypeFloat 32
%10 = OpTypeVector %9 4
%7 = OpTypeRuntimeArray %10
%8 = OpTypeStruct %7
%11 = OpTypePointer StorageBuffer %8
%12 = OpTypeVoid
%13 = OpTypeFunction %12
%14 = OpTypePointer StorageBuffer %7
%2 = OpVariable  %11  StorageBuffer
%15 = OpTypeInt 32 0
%16 = OpConstant  %15  0
%17 = OpTypePointer Input %15
%3 = OpVariable  %17  Input
%18 = OpTypeBool
%19 = OpTypePointer StorageBuffer %10
%20 = OpTypePointer Output %10
%4 = OpVariable  %20  Output
