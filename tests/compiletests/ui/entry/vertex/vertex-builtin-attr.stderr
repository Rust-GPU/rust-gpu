OpCapability Shader
OpCapability DrawParameters
OpMemoryModel Logical Simple
OpEntryPoint Vertex %1 "vertex" %2 %3 %4 %5 %6 %7
OpName %2 "vertex_index"
OpName %3 "instance_index"
OpName %4 "base_vertex"
OpName %5 "base_instance"
OpName %6 "draw_index"
OpName %7 "position_out"
OpDecorate %2 BuiltIn VertexIndex
OpDecorate %3 BuiltIn InstanceIndex
OpDecorate %4 BuiltIn BaseVertex
OpDecorate %5 BuiltIn BaseInstance
OpDecorate %6 BuiltIn DrawIndex
OpDecorate %7 BuiltIn Position
%10 = OpTypeFloat 32
%11 = OpTypeVector %10 4
%12 = OpTypePointer Output %11
%13 = OpTypeInt 32 0
%14 = OpTypePointer Input %13
%15 = OpTypeVoid
%16 = OpTypeFunction %15
%2 = OpVariable  %14  Input
%3 = OpVariable  %14  Input
%4 = OpVariable  %14  Input
%5 = OpVariable  %14  Input
%6 = OpVariable  %14  Input
%7 = OpVariable  %12  Output
