OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint Vertex %1 "vertex" %2 %3 %4
OpName %2 "buffer_positions"
OpName %3 "vertex_index"
OpName %4 "position_out"
OpDecorate %6 ArrayStride 16
OpDecorate %7 Block
OpMemberDecorate %7 0 Offset 0
OpDecorate %2 NonWritable
OpDecorate %2 Binding 0
OpDecorate %2 DescriptorSet 0
OpDecorate %3 BuiltIn VertexIndex
OpDecorate %4 BuiltIn Position
%8 = OpTypeFloat 32
%9 = OpTypeVector %8 4
%6 = OpTypeRuntimeArray %9
%7 = OpTypeStruct %6
%10 = OpTypePointer StorageBuffer %7
%11 = OpTypeInt 32 0
%12 = OpTypePointer Input %11
%13 = OpTypePointer Output %9
%14 = OpTypeVoid
%15 = OpTypeFunction %14
%16 = OpTypePointer StorageBuffer %6
%2 = OpVariable  %10  StorageBuffer
%17 = OpConstant  %11  0
%3 = OpVariable  %12  Input
%18 = OpTypeBool
%19 = OpTypePointer StorageBuffer %9
%4 = OpVariable  %13  Output
