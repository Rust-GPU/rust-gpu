               OpCapability Shader
               OpMemoryModel Logical Simple
               OpEntryPoint Fragment %1 "main"
               OpExecutionMode %1 OriginUpperLeft
          %2 = OpString "$DIR/generic-fn-op-name.rs"
               OpName %generic_fn_op_name__main "generic_fn_op_name::main"
               OpName %generic_fn_op_name__generic___f32___generic_fn_op_name__Dimensionality__TwoD__ "generic_fn_op_name::generic::<f32, {generic_fn_op_name::Dimensionality::TwoD}>"
       %void = OpTypeVoid
          %6 = OpTypeFunction %void
