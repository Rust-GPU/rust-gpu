               OpCapability Shader
               OpMemoryModel Logical Simple
               OpEntryPoint Fragment %1 "main" %out
               OpExecutionMode %1 OriginUpperLeft
          %3 = OpString "$DIR/spec_constant-attr.rs"
               OpName %no_default "no_default"
               OpName %default_0 "default_0"
               OpName %default_123 "default_123"
               OpName %max_id_and_default "max_id_and_default"
               OpName %out "out"
               OpDecorate %no_default SpecId 1
               OpDecorate %default_0 SpecId 2
               OpDecorate %default_123 SpecId 123
               OpDecorate %max_id_and_default SpecId 4294967295
               OpDecorate %out Location 0
        %u32 = OpTypeInt 32 0
%_ptr_Output_u32 = OpTypePointer Output %u32
       %void = OpTypeVoid
         %11 = OpTypeFunction %void
 %no_default = OpSpecConstant %u32 0
  %default_0 = OpSpecConstant %u32 0
%default_123 = OpSpecConstant %u32 123
%max_id_and_default = OpSpecConstant %u32 4294967295
        %out = OpVariable %_ptr_Output_u32 Output
