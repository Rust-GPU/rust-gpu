               OpCapability Shader
               OpMemoryModel Logical Simple
               OpEntryPoint GLCompute %1 "main_cs" %_id
               OpEntryPoint Fragment %3 "main_fs"
               OpEntryPoint Vertex %4 "main_vs" %_v
               OpExecutionMode %1 LocalSize 64 1 1
               OpExecutionMode %3 OriginUpperLeft
          %6 = OpString "$DIR/issue-590-multiple-entry-points.rs"
               OpName %_id "_id"
               OpName %_v "_v"
               OpName %issue_590_multiple_entry_points__main_cs "issue_590_multiple_entry_points::main_cs"
               OpName %issue_590_multiple_entry_points__main_fs "issue_590_multiple_entry_points::main_fs"
               OpName %issue_590_multiple_entry_points__main_vs "issue_590_multiple_entry_points::main_vs"
               OpDecorate %_id BuiltIn GlobalInvocationId
               OpDecorate %_v BuiltIn VertexIndex
        %u32 = OpTypeInt 32 0
      %v3u32 = OpTypeVector %u32 3
%_ptr_Input_v3u32 = OpTypePointer Input %v3u32
       %void = OpTypeVoid
         %14 = OpTypeFunction %void
        %_id = OpVariable %_ptr_Input_v3u32 Input
         %15 = OpTypeFunction %void %v3u32
        %i32 = OpTypeInt 32 1
%_ptr_Input_i32 = OpTypePointer Input %i32
         %_v = OpVariable %_ptr_Input_i32 Input
