               OpCapability Shader
               OpCapability Float64
               OpMemoryModel Logical Simple
               OpEntryPoint Fragment %1 "main" %output
               OpExecutionMode %1 OriginUpperLeft
          %3 = OpString "$DIR/const-float-cast.rs"
               OpName %output "output"
               OpDecorate %output Location 0
        %f32 = OpTypeFloat 32
%_ptr_Output_f32 = OpTypePointer Output %f32
       %void = OpTypeVoid
          %7 = OpTypeFunction %void
        %f64 = OpTypeFloat 64
%f64_123_456 = OpConstant %f64 123.456
     %output = OpVariable %_ptr_Output_f32 Output
   %f64_20_5 = OpConstant %f64 20.5
      %f32_1 = OpConstant %f32 1
   %f32_20_5 = OpConstant %f32 20.5
        %u32 = OpTypeInt 32 0
     %u32_42 = OpConstant %u32 42
