OpCapability Shader
OpMemoryModel Logical Simple
OpEntryPoint Vertex %1 "main" %2 %3 %4
OpName %7 "A"
OpMemberName %7 0 "0"
OpName %2 "tid"
OpName %3 "a"
OpName %4 "at"
OpDecorate %2 BuiltIn LocalInvocationIndex
OpDecorate %3 Location 0
OpDecorate %4 Location 1
%8 = OpTypeInt 32 0
%9 = OpTypeVector %8 3
%7 = OpTypeStruct %9
%10 = OpTypePointer Output %7
%11 = OpTypePointer Input %8
%12 = OpTypeVoid
%13 = OpTypeFunction %12
%2 = OpVariable  %11  Input
%14 = OpConstant  %8  1
%15 = OpConstant  %8  2
%16 = OpTypePointer Output %9
%3 = OpVariable  %10  Output
%17 = OpConstant  %8  0
%18 = OpConstant  %8  3
%19 = OpTypePointer Output %8
%20 = OpConstant  %8  10
%21 = OpConstant  %8  4
%4 = OpVariable  %10  Output
%22 = OpConstant  %8  5
%23 = OpConstant  %8  11
%1 = OpFunction  %12  None %13
%24 = OpLabel
%25 = OpLoad  %8  %2
%26 = OpCompositeConstruct  %9  %25 %14 %15
%27 = OpInBoundsAccessChain  %16  %3 %17
OpStore %27 %26
%28 = OpCompositeConstruct  %9  %25 %14 %18
%29 = OpInBoundsAccessChain  %16  %3 %17
OpStore %29 %28
%30 = OpInBoundsAccessChain  %19  %3 %17 %14
%31 = OpInBoundsAccessChain  %19  %3 %17 %14
%32 = OpLoad  %8  %31
%33 = OpIAdd  %8  %32 %20
OpStore %30 %33
%34 = OpCompositeConstruct  %9  %25 %14 %21
%35 = OpInBoundsAccessChain  %16  %4 %17
OpStore %35 %34
%36 = OpCompositeConstruct  %9  %25 %14 %22
%37 = OpInBoundsAccessChain  %16  %4 %17
OpStore %37 %36
%38 = OpInBoundsAccessChain  %19  %4 %17 %14
%39 = OpInBoundsAccessChain  %19  %4 %17 %14
%40 = OpLoad  %8  %39
%41 = OpIAdd  %8  %40 %23
OpStore %38 %41
OpNoLine
OpReturn
OpFunctionEnd
